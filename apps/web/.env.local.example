# Supabase (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL_UNPOOLED=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Auth0 (reuse text-labelling-app tenant)
AUTH0_SECRET=use-a-random-32-char-string-here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Upstash Redis (item cache, session cache, rate limiting)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# HuggingFace (for private datasets and export)
HF_TOKEN=hf_xxx
