# Supabase (PostgreSQL)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL_UNPOOLED=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Auth0 (reuse text-labelling-app tenant) — v4 SDK env vars
AUTH0_SECRET=use-a-random-32-char-string-here
AUTH0_DOMAIN=your-tenant.eu.auth0.com
APP_BASE_URL=http://localhost:3000
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Upstash Redis (item cache, session cache, rate limiting)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# HuggingFace (for private datasets and export)
HF_TOKEN=hf_xxx
